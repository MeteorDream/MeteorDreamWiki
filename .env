# MeteorDreamWiki — Obsidian Wiki configuration
# Generated by /wiki-setup on 2026-06-06

# ─── Vault ──────────────────────────────────────────────────────────────────
# Vault root. Relative to the project root (this repo IS the vault).
# Consumers should resolve against the directory containing this .env file.
OBSIDIAN_VAULT_PATH=.

# ─── Sources ────────────────────────────────────────────────────────────────
# Comma-separated list of directories that wiki-ingest should scan for sources.
# Relative paths are resolved against OBSIDIAN_VAULT_PATH.
OBSIDIAN_SOURCES_DIR=_raw

# ─── Agent history (auto-discover) ──────────────────────────────────────────
# Leave these set to enable the *-history-ingest skills.
CLAUDE_HISTORY_PATH=~/.claude
CODEX_HISTORY_PATH=~/.codex
HERMES_HISTORY_PATH=~/.hermes

# ─── QMD (semantic search) — optional ───────────────────────────────────────
# Uncomment and configure if you have QMD installed. Falls back to Grep otherwise.
# QMD_WIKI_COLLECTION=meteor-dream-wiki
# QMD_PAPERS_COLLECTION=meteor-dream-papers
# QMD_TRANSPORT=mcp
# QMD_CLI_SEARCH_MODE=quality

# ─── Token budget ───────────────────────────────────────────────────────────
# Warn when a full-wiki read would cost more than this many tokens. 0 to disable.
WIKI_TOKEN_WARN_THRESHOLD=100000

# ─── Staged writes ──────────────────────────────────────────────────────────
# Set to true to route all LLM-written pages through _staging/ for review.
WIKI_STAGED_WRITES=false
